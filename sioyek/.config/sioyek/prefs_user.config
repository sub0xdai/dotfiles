# Font
ui_font JetBrainsMono Nerd Font

# Clipboard
copy_on_select 1

# Fit width on open
#default_zoom_level 1

# === MONOCHROME AMOLED === #
# Viewport background: black, blends with stoic template
background_color           #000000

# ── Highlights ──
text_highlight_color       #999999
visual_mark_color          #666666

search_highlight_color     #AAAAAA
link_highlight_color       #888888
synctex_highlight_color    #BBBBBB

highlight_color_a          #999999
highlight_color_b          #AAAAAA
highlight_color_c          #BBBBBB
highlight_color_d          #888888
highlight_color_e          #777777
highlight_color_f          #666666
highlight_color_g          #999999

# ── Custom color mode disabled (Template controls document colors) ──
# custom_background_color    #1e1e2e
# custom_text_color          #cdd6f4

# ── UI Chrome ──
ui_text_color              #BBBBBB
ui_background_color        #111111
ui_selected_text_color     #EEEEEE
ui_selected_background_color #333333

status_bar_color           #111111
status_bar_text_color      #999999
