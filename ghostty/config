#  Ghostty configuration
font-family = JetBrainsMono Nerd Font
font-size = 14

# Terminal settings
term = xterm-256color

# Window settings
background-opacity = 0.9
window-decoration = false
window-padding-x = 4
window-padding-y = 4

# Hide mouse typing
mouse-hide-while-typing = true

# Theme
theme = "Kanso Zen"
cursor-style = "underline"


